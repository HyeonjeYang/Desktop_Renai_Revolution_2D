        [`그럼 빨리 만나요~`, 'O_interest'],
      ]},
      { words:['자자','잘자','굿나잇','굿밤'], aff:1, lines:[
        [`선배 잘 자요~ 꿈에서 봐요`, 'O_default'],
        [`히히 잘 들어가세요~`, 'O_interest'],
      ]},
    ],
    fallback: [
      [`선배 그게 뭐예요?`, 'O_interest'],
      [`히히 그렇구나~`, 'O_interest'],
      [`선배!!`, 'O_surprise'],
      [`헐 진짜요?`, 'O_surprise'],
      [`아 그런 거예요?`, 'O_default'],
    ],
    fallbackAff: 0,
    personaTag: '장난끼 후배',
  },
};

// Patch nuna idle/keyword lines that need userName at runtime
function expandNunaTemplates(u) {
  // The nuna lines reference nm('','') which evaluates wrong since u not yet set when LINES was defined.
  // We'll evaluate dialogue lazily in pick() by re-running. For idle we use the function form.
  // For keywords with name, we substitute at runtime via a marker.
}

// ============ HELPERS ============
function pick(arr) { return arr[Math.floor(Math.random()*arr.length)]; }

function getImg(key) {
  if (!glassesOn) key = key.replace('O_','X_');
  return IMGS[key] || IMGS['O_default'];
}

function showBubble(text, imgKey, duration) {
  if (!duration) duration = 3000;
  clearTimeout(bubbleTimer);
  const b = document.getElementById('bubble');
  b.textContent = text;
  b.classList.add('show');
  const ci = document.getElementById('charImg');
  ci.src = getImg(imgKey);
  if (imgKey.indexOf('surprise') !== -1) {
    document.getElementById('charArea').classList.add('shaking');
    setTimeout(function(){document.getElementById('charArea').classList.remove('shaking');}, 350);
  }
  bubbleTimer = setTimeout(function(){
    b.classList.remove('show');
    ci.src = getImg(glassesOn?'O_default':'X_default');
  }, duration);
}

// Substitute {U} marker in lines with username particle
function fillName(text) {
  // replace {U:는}, {U:가}, {U}, etc.
  return text.replace(/\{U:([^}]+)\}/g, function(_, p) {
    return nm(userName, p);
  }).replace(/\{U\}/g, function() {
    return nm(userName, '');
  });
}

function changeAffection(delta) {
  if (!delta) return;
  affection = Math.max(0, Math.min(100, affection + delta));
  document.getElementById('affFill').style.width = affection + '%';
  document.getElementById('affValue').textContent = affection;
  showAffectionDelta(delta);
}

function showAffectionDelta(delta) {
  const el = document.createElement('span');
  el.className = 'aff-delta';
  el.textContent = (delta > 0 ? '+' : '') + delta;
  el.style.color = delta > 0 ? '#e57aa6' : '#9b7aaa';
  document.getElementById('affBar').appendChild(el);
  setTimeout(function(){ el.remove(); }, 1400);
}

function startIdle() {
  clearTimeout(idleTimer);
  const delay = 7000 + Math.random()*10000;
  idleTimer = setTimeout(function(){
    const d = LINES[persona];
    const choice = pick(d.idle(userName));
    showBubble(choice[0], choice[1], 3500);
    startIdle();
  }, delay);
}

// ============ ZONE HANDLER ============
function onZone(zone) {
  if (locked) return;
  locked = true; setTimeout(function(){locked=false;}, 700);
  clearTimeout(idleTimer);

  const d = LINES[persona];
  let choice;

  if (zone === 'glasses') {
    if (glassesOn) {
      glassesOn = false;
      choice = pick(d.zones.glasses_off);
    } else {
      glassesOn = true;
      choice = pick(d.zones.glasses_on);
    }
  } else {
    const zoneLines = d.zones[zone];
    if (!zoneLines) return;
    choice = pick(zoneLines);
  }

  showBubble(fillName(choice[0]), choice[1], 2800);
  changeAffection(d.aff[zone] || 0);
  setTimeout(startIdle, 3200);
}

// ============ TEXT INPUT ============
function sendMsg() {
  const input = document.getElementById('chatInput');
  const msg = input.value.trim();
  if (!msg) return;
  input.value = '';

  document.getElementById('userSaid').textContent = '"' + msg + '"';
  clearTimeout(idleTimer);

  const d = LINES[persona];
  const lower = msg.toLowerCase();

  if (charName && lower.indexOf(charName.toLowerCase()) !== -1) {
    showBubble(fillName(d.nameReact[0]), d.nameReact[1], 2800);
    changeAffection(d.nameAff || 0);
    setTimeout(startIdle, 3200);
    return;
  }

  for (let i = 0; i < d.keywords.length; i++) {
    const kw = d.keywords[i];
    let matched = false;
    for (let j = 0; j < kw.words.length; j++) {
      if (lower.indexOf(kw.words[j]) !== -1) { matched = true; break; }
    }
    if (matched) {
      const choice = pick(kw.lines);
      showBubble(fillName(choice[0]), choice[1], 3000);
      changeAffection(kw.aff || 0);
      setTimeout(startIdle, 3500);
      return;
    }
  }

  const f = pick(d.fallback);
  showBubble(fillName(f[0]), f[1], 2500);
  changeAffection(d.fallbackAff || 0);
  setTimeout(startIdle, 3000);
}

// ============ SETUP / TOGGLES ============
function selectPersona(btn) {
  const buttons = document.querySelectorAll('.persona-btn');
  for (let i = 0; i < buttons.length; i++) buttons[i].classList.remove('selected');
  btn.classList.add('selected');
  selectedPersona = btn.dataset.p;
}

function startApp() {
  const u = document.getElementById('userName').value.trim();
  const c = document.getElementById('charName').value.trim();
  if (!u) { alert('이름을 입력해주세요!'); return; }
  if (!c) { alert('캐릭터 이름도 알려주세요!'); return; }
  if (!selectedPersona) { alert('성격을 선택해주세요!'); return; }

  userName = u; charName = c; persona = selectedPersona;
  affection = 50;
  document.getElementById('affFill').style.width = '50%';
  document.getElementById('affValue').textContent = '50';

  document.getElementById('setupScreen').style.display = 'none';
  document.getElementById('widget').style.display = 'flex';
  document.getElementById('personaTag').textContent = LINES[persona].personaTag;

  glassesOn = true;
  const greeting = LINES[persona].greeting(userName, charName);
  setTimeout(function(){
    showBubble(greeting[0], greeting[1], 4000);
    setTimeout(startIdle, 4500);
  }, 400);
}

function changePersona() {
  document.getElementById('setupScreen').style.display='flex';
  document.getElementById('widget').style.display='none';
  clearTimeout(idleTimer); clearTimeout(bubbleTimer);
}

function toggleWidget() {
  const area = document.getElementById('charArea');
  const input = document.querySelector('.input-area');
  const aff = document.getElementById('affBar');
  minimized = !minimized;
  area.style.display = minimized ? 'none' : '';
  input.style.display = minimized ? 'none' : '';
  aff.style.display = minimized ? 'none' : '';
  document.getElementById('minBtn').textContent = minimized ? '+' : '━';
}
</script>
</body>
</html>
