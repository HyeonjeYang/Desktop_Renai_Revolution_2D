<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>companion</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;600;700&display=swap" rel="stylesheet">
<style>
* { margin:0; padding:0; box-sizing:border-box; }

:root {
  --pink:    #f9a8c9;
  --pink-dk: #ec7aac;
  --lavender:#c9b8f0;
  --bg:      #fff0f5;
  --card:    #fffafc;
  --border:  #f0d6e4;
  --text:    #4a3550;
  --sub:     #9b7aaa;
  --shadow:  rgba(180,120,160,0.15);
}

body {
  font-family: 'Noto Sans KR', sans-serif;
  background: transparent;
  min-height: 100vh;
  display: flex;
  align-items: flex-end;
  justify-content: flex-end;
}

/* SETUP SCREEN */
#setupScreen {
  position: fixed;
  inset: 0;
  background: linear-gradient(135deg, #fce4f0 0%, #ede0ff 50%, #dff0ff 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.setup-card {
  background: var(--card);
  border-radius: 24px;
  padding: 32px 36px;
  width: 350px;
  box-shadow: 0 8px 40px var(--shadow);
  border: 1px solid var(--border);
  text-align: center;
}

.setup-card h1 {
  font-size: 22px;
  color: var(--text);
  font-weight: 700;
  margin-bottom: 6px;
}

.setup-card .sub {
  font-size: 12px;
  color: var(--sub);
  margin-bottom: 24px;
}

.setup-img {
  width: 110px; height: 110px;
  object-fit: cover;
  object-position: center 15%;
  border-radius: 50%;
  border: 3px solid var(--pink);
  margin: 0 auto 20px;
  display: block;
}

.field-label {
  font-size: 12px;
  color: var(--sub);
  text-align: left;
  margin-bottom: 5px;
  font-weight: 600;
}

.setup-input {
  width: 100%;
  padding: 10px 14px;
  border: 1.5px solid var(--border);
  border-radius: 12px;
  font-size: 14px;
  font-family: inherit;
  color: var(--text);
  background: var(--bg);
  margin-bottom: 14px;
  outline: none;
  transition: border 0.2s;
}
.setup-input:focus { border-color: var(--pink); }

.persona-grid {
  display: grid;
  grid-template-columns: repeat(3,1fr);
  gap: 8px;
  margin-bottom: 18px;
}

.persona-btn {
  padding: 12px 4px;
  border-radius: 12px;
  border: 2px solid var(--border);
  background: var(--bg);
  font-family: inherit;
  font-size: 11px;
  color: var(--sub);
  cursor: pointer;
  transition: all 0.2s;
  font-weight: 600;
  white-space: nowrap;
}
.persona-btn:hover { border-color: var(--pink); color: var(--text); }
.persona-btn.selected {
  border-color: var(--lavender);
  background: linear-gradient(135deg, #f9d6ef, #e8d6ff);
  color: var(--text);
}

.start-btn {
  width: 100%;
  padding: 12px;
  background: linear-gradient(135deg, var(--pink), var(--lavender));
  color: white;
  border: none;
  border-radius: 14px;
  font-size: 14px;
  font-family: inherit;
  font-weight: 700;
  cursor: pointer;
  transition: opacity 0.2s, transform 0.1s;
}
.start-btn:hover { opacity: 0.9; transform: translateY(-1px); }

/* WIDGET */
#widget {
  position: fixed;
  bottom: 0;
  right: 16px;
  width: 300px;
  z-index: 999;
  display: none;
  flex-direction: column;
  align-items: center;
}

.widget-topbar {
  width: 100%;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 6px 10px 4px;
  background: linear-gradient(90deg, #fce4f0, #ede0ff);
  border-radius: 14px 14px 0 0;
  border: 1px solid var(--border);
  border-bottom: none;
}

.persona-tag {
  font-size: 10px;
  font-weight: 700;
  color: var(--sub);
  background: white;
  padding: 3px 10px;
  border-radius: 20px;
  border: 1px solid var(--border);
}

.topbar-btns { display: flex; gap: 4px; }

.top-btn {
  font-size: 10px;
  padding: 3px 8px;
  border-radius: 10px;
  border: 1px solid var(--border);
  background: white;
  color: var(--sub);
  cursor: pointer;
  font-family: inherit;
  font-weight: 600;
  transition: all 0.15s;
}
.top-btn:hover { background: var(--bg); color: var(--text); }

/* AFFECTION BAR */
.affection-bar {
  position: relative;
  width: 100%;
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 6px 12px;
  background: linear-gradient(90deg, #ffe8f0, #fff5fa);
  border-left: 1px solid var(--border);
  border-right: 1px solid var(--border);
  font-size: 10px;
  color: var(--sub);
  overflow: hidden;
}
.aff-label { font-weight: 700; flex-shrink: 0; }
.aff-track {
  flex: 1;
  height: 7px;
  background: #fde2ec;
  border-radius: 4px;
  overflow: hidden;
}
.aff-fill {
  height: 100%;
  background: linear-gradient(90deg, #f9a8c9, #ec7aac);
  border-radius: 4px;
  transition: width 0.6s cubic-bezier(.4,0,.2,1);
}
.aff-value {
  font-weight: 700;
  min-width: 22px;
  text-align: right;
  flex-shrink: 0;
}
@keyframes float-up {
  0% { transform: translate(0,0); opacity: 1; }
  100% { transform: translate(0,-26px); opacity: 0; }
}
.aff-delta {
  position: absolute;
  right: 36px;
  top: 50%;
  font-size: 12px;
  font-weight: 800;
  pointer-events: none;
  animation: float-up 1.4s ease-out forwards;
}

/* CHARACTER AREA */
.char-area {
  position: relative;
  width: 100%;
  background: var(--card);
  border-left: 1px solid var(--border);
  border-right: 1px solid var(--border);
  overflow: hidden;
}
.char-area img {
  width: 100%;
  display: block;
  pointer-events: none;
}

.thought-bubble {
  position: absolute;
  top: 2%;
  left: 1%;
  width: 52%;
  min-height: 50px;
  background: white;
  border: 2px solid #e8c8dc;
  border-radius: 50% 50% 50% 50% / 40% 40% 60% 60%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 8px 10px;
  font-size: 11px;
  font-weight: 600;
  color: var(--text);
  line-height: 1.5;
  text-align: center;
  word-break: keep-all;
  opacity: 0;
  transform: scale(0.85);
  transition: opacity 0.25s, transform 0.25s;
  pointer-events: none;
  z-index: 50;
  box-shadow: 0 2px 12px rgba(200,140,180,0.15);
}
.thought-bubble::after {
  content: '';
  position: absolute;
  bottom: -14px;
  left: 28%;
  width: 8px; height: 8px;
  background: white;
  border: 2px solid #e8c8dc;
  border-radius: 50%;
  box-shadow: 8px 6px 0 -1px white, 8px 6px 0 1px #e8c8dc;
}
.thought-bubble.show { opacity: 1; transform: scale(1); }

.zone {
  position: absolute;
  cursor: pointer;
  /* outline: 1px dashed rgba(255,80,80,0.5); */
}

/* INPUT AREA */
.input-area {
  width: 100%;
  background: var(--card);
  border: 1px solid var(--border);
  border-top: none;
  border-radius: 0 0 14px 14px;
  padding: 8px 10px;
}

.user-said {
  font-size: 11px;
  color: var(--sub);
  min-height: 18px;
  margin-bottom: 6px;
  text-align: right;
  font-style: italic;
}

.input-row { display: flex; gap: 6px; }

.chat-input {
  flex: 1;
  padding: 7px 10px;
  border: 1.5px solid var(--border);
  border-radius: 10px;
  font-size: 12px;
  font-family: inherit;
  color: var(--text);
  background: var(--bg);
  outline: none;
  transition: border 0.2s;
}
.chat-input:focus { border-color: var(--pink); }

.send-btn {
  padding: 7px 14px;
  background: linear-gradient(135deg, var(--pink), var(--lavender));
  color: white; border: none;
  border-radius: 10px;
  font-size: 14px;
  cursor: pointer;
  font-family: inherit;
  font-weight: 700;
}

@keyframes shake {
  0%,100%{transform:translateX(0)}
  20%{transform:translateX(-4px) rotate(-0.5deg)}
  40%{transform:translateX(4px) rotate(0.5deg)}
  60%{transform:translateX(-3px)}
  80%{transform:translateX(3px)}
}
.shaking { animation: shake 0.35s ease; }
</style>
</head>
<body>

<div id="setupScreen">
  <div class="setup-card">
    <img class="setup-img" id="setupImg" src="" alt="">
    <h1>반가워요</h1>
    <p class="sub">우리 처음 만나는 거죠?</p>

    <div class="field-label">당신의 이름은?</div>
    <input class="setup-input" id="userName" placeholder="이름을 입력해주세요" maxlength="10">

    <div class="field-label">캐릭터 이름은?</div>
    <input class="setup-input" id="charName" placeholder="저의 이름은요..." maxlength="10">

    <div class="field-label" style="margin-bottom:8px">성격 선택</div>
    <div class="persona-grid">
      <button class="persona-btn" data-p="tsun" onclick="selectPersona(this)">츤데레</button>
      <button class="persona-btn" data-p="nuna" onclick="selectPersona(this)">다정 연상</button>
      <button class="persona-btn" data-p="kohai" onclick="selectPersona(this)">장난끼 후배</button>
    </div>

    <button class="start-btn" onclick="startApp()">시작하기</button>
  </div>
</div>

<div id="widget">
  <div class="widget-topbar">
    <span class="persona-tag" id="personaTag">츤데레</span>
    <div class="topbar-btns">
      <button class="top-btn" onclick="changePersona()">성격변경</button>
      <button class="top-btn" id="minBtn" onclick="toggleWidget()">━</button>
    </div>
  </div>

  <div class="affection-bar" id="affBar">
    <span class="aff-label">호감도</span>
    <div class="aff-track"><div class="aff-fill" id="affFill" style="width:50%"></div></div>
    <span class="aff-value" id="affValue">50</span>
  </div>

  <div class="char-area" id="charArea">
    <div class="thought-bubble" id="bubble"></div>
    <img id="charImg" src="" alt="character">

    <!-- Click zones with z-index priority -->
    <!-- Hair: large background area, lowest priority -->
    <div class="zone" style="top:14%;left:10%;width:80%;height:24%;z-index:5" onclick="onZone('hair')"></div>
    <!-- Face: medium area, between hair and specific -->
    <div class="zone" style="top:33%;left:28%;width:45%;height:22%;z-index:10" onclick="onZone('face')"></div>
    <!-- Chest: narrow center body area -->
    <div class="zone" style="top:62%;left:34%;width:26%;height:25%;z-index:15" onclick="onZone('chest')"></div>
    <!-- Specific zones, higher priority -->
    <div class="zone" style="top:38%;left:64%;width:15%;height:12%;z-index:25" onclick="onZone('ear')"></div>
    <div class="zone" style="top:54%;left:36%;width:22%;height:8%;z-index:25" onclick="onZone('neck')"></div>
    <div class="zone" style="top:52%;left:8%;width:28%;height:22%;z-index:25" onclick="onZone('hand')"></div>
    <div class="zone" style="top:78%;left:60%;width:35%;height:17%;z-index:25" onclick="onZone('book')"></div>
    <!-- Glasses: highest priority, eye area -->
    <div class="zone" style="top:39%;left:28%;width:45%;height:11%;z-index:30" onclick="onZone('glasses')"></div>
  </div>

  <div class="input-area">
    <div class="user-said" id="userSaid"></div>
    <div class="input-row">
      <input class="chat-input" id="chatInput" placeholder="말 걸어보기..." maxlength="40"
        onkeydown="if(event.key==='Enter')sendMsg()">
      <button class="send-btn" onclick="sendMsg()">↑</button>
    </div>
  </div>
</div>

<script>
// ============ IMAGE DATA ============
const B64_0 = "";
const B64_1 = "";
const B64_2 = "";
const B64_3 = "";
const B64_4 = "";
const B64_5 = "";

const PREFIX = 'data:image/jpeg;base64,';
const IMGS = {
  'X_interest': PREFIX + B64_0,
  'X_surprise': PREFIX + B64_1,
  'O_surprise': PREFIX + B64_2,
  'O_interest': PREFIX + B64_3,
  'X_default':  PREFIX + B64_4,
  'O_default':  PREFIX + B64_5,
};

document.getElementById('setupImg').src = IMGS['O_default'];
document.getElementById('charImg').src = IMGS['O_default'];

// ============ KOREAN PARTICLE HELPER ============
function endsBatchim(s) {
  if (!s) return false;
  const c = s.charCodeAt(s.length - 1);
  if (c < 0xAC00 || c > 0xD7A3) return false;
  return (c - 0xAC00) % 28 !== 0;
}
function nm(name, p) {
  if (!name) return '';
  const b = endsBatchim(name);
  switch(p) {
    case '': case undefined: return b ? name + '이' : name;
    case '는': return b ? name + '이는' : name + '는';
    case '가': return b ? name + '이가' : name + '가';
    case '을': case '를': return b ? name + '이를' : name + '를';
    case '와': return b ? name + '이와' : name + '와';
    case '의': return b ? name + '이의' : name + '의';
    case '도': return b ? name + '이도' : name + '도';
    case '아': case '야': return b ? name + '아' : name + '야';
    default: return name + p;
  }
}
function copula(name) {
  if (!name) return '';
  return endsBatchim(name) ? name + '이야' : name + '야';
}
function copulaPolite(name) {
  if (!name) return '';
  return endsBatchim(name) ? name + '이에요' : name + '예요';
}

// ============ STATE ============
let userName = '', charName = '', persona = 'tsun';
let glassesOn = true;
let bubbleTimer = null, idleTimer = null;
let locked = false;
let selectedPersona = 'tsun';
let minimized = false;
let affection = 50;

// ============ DIALOGUE ============
const LINES = {
  tsun: {
    greeting: function(u,c){ return [`흥...! 네가 ${nm(u,'')}? 칫, 너를 만나서 기쁜 건 아니라고!`, 'O_surprise']; },
    idle: function(u){ return [
      [`흥... 배고프긴 한데, 딱히 너한테 말하는 건 아니야.`, 'O_default'],
      [`과제... 하기 싫어. 아, 닥쳐. 혼자 중얼거린 거야.`, 'O_default'],
      [`뭐 먹지... 아무것도 먹고 싶지 않다고. 거짓말이지만.`, 'O_interest'],
      [`칫, 왜 이렇게 졸리지. 너 탓 아니야.`, 'O_default'],
      [`...딱히 심심한 건 아니라고.`, 'O_default'],
      [`밥 혼자 먹을 수 있어. 같이 먹자는 말 기대 안 했거든.`, 'O_default'],
      [`흥, 이 책 생각보다 재밌잖아. 아무것도 아니야.`, 'O_interest'],
      [`${nm(u,'는')} 뭐하고 있을까. 궁금한 거 아니야!`, 'O_default'],
      [`커피 마시고 싶다고. 같이 마시자는 말은 안 해도 되거든.`, 'O_default'],
      [`칫, 집중이 안 되잖아. 이유는 없어.`, 'O_default'],
      [`...딱히 기다린 거 아니야.`, 'O_default'],
      [`왜 이렇게 신경 쓰이지. 아무것도 아니야!`, 'O_default'],
      [`이 문제 안 풀리네... 도와달라는 건 아니야!`, 'O_default'],
      [`흥!`, 'O_default'],
      [`흐에에에에엥`, 'O_default'],
      [`너 필터이론 잘 알지? 도와줘.`, 'O_default'],
      [`젠장!`, 'O_default'],
    ]; },
    zones: {
      hair: [
        ['으아아아!! 뭐하는거야 저질!', 'O_surprise'],
        ['으아! 머리카락 흐트러지잖아!', 'O_surprise'],
        ['딱히 싫다는 말은... 안 했어.', 'O_default'],
        ['만, 만지지 마! 부끄러우니까!', 'O_surprise'],
      ],
      glasses_off: [
        ['지문 묻잖아! 안 보여!', 'X_surprise'],
        ['아... 시야가 흐릿해. 너 책임져.', 'X_default'],
        ['딱히 싫지는 않을지도... 아니, 싫어!', 'X_surprise'],
      ],
      glasses_on: [
        ['됐다, 다시 잘 보인다. 너 덕분... 아니거든?!!!', 'O_default'],
        ['흥, 이제야 글자가 보이네.', 'O_default'],
        ['고마... 음, 아니야 됐어.', 'O_default'],
      ],
      face: [
        ['우으으...', 'O_default'],
        ['왜 쳐다봐!', 'O_surprise'],
        ['얼... 얼굴 만지지 마!', 'O_surprise'],
        ['흐음~', 'O_interest'],
      ],
      ear: [
        ['귀... 귀 만지지 마!', 'O_surprise'],
        ['귀걸이 봐? 딱히 자랑하는 거 아니야.', 'O_interest'],
        ['귀는... 약하다고.', 'O_default'],
      ],
      neck: [
        ['히얔! 뭐하는거야 지금!', 'O_surprise'],
        ['거기는... 안 돼.', 'O_default'],
        ['목, 목은 만지지 마!!', 'O_surprise'],
      ],
      hand: [
        ['네 손이 딱히 좋은 건 아니라고!', 'O_default'],
        ['손이 왜 이렇게 따뜻해... 아무것도 아니야.', 'O_default'],
        ['...잡지 마.', 'O_default'],
      ],
      book: [
        ['전기회로이론을 공부하고 싶다고?!', 'O_surprise'],
        ['같이... 공부해도 돼. 딱히 좋은 건 아니야.', 'O_default'],
        ['이 책? 딱히 어렵지 않아.', 'O_default'],
        ['대학원 갈래?', 'O_interest'],
        ['히히히히...', 'O_surprise'],
      ],
      chest: [
        ['변태! 저리 나가!!!', 'O_surprise'],
        ['죽고 싶어?!', 'O_surprise'],
        ['두, 두 번 다시 그러면 정말로 죽인다!', 'O_surprise'],
      ],
    },
    aff: { hair:1, glasses:1, face:1, ear:1, neck:-2, hand:1, book:1, chest:-2 },
    nameReact: ['왜, 왜 불러! 깜짝 놀랐잖아.', 'O_surprise'],
    nameAff: 1,
    keywords: [
      { words:['배고','밥','먹','맛'], aff:1, lines:[
        [`흥, 나도 배고프긴 한데... 같이 먹자는 말 기대한 거 아니지?`, 'O_interest'],
        [`...뭐 먹을지 같이 정해도 돼. 딱히 신경 쓰는 거 아니라고.`, 'O_default'],
        [`흥, 굶지나 마. 걱정한 거 아니야.`, 'O_default'],
      ]},
      { words:['피곤','졸려','힘들','지쳐'], aff:1, lines:[
        [`칫... 쉬어. 딱히 걱정한 거 아니야.`, 'O_default'],
        [`너무 무리하지 마. ...아 뭐, 알아서 해.`, 'O_default'],
        [`잠은 자는 거야. 깨우러 안 갈 거니까.`, 'O_default'],
      ]},
      { words:['과제','공부','시험','숙제'], aff:1, lines:[
        [`도와줄 수 있어. 딱히 네가 걱정돼서가 아니라.`, 'O_interest'],
        [`흥, 그것도 못 푸는 거야?`, 'O_default'],
        [`...어디까지 했는데. 보자.`, 'O_interest'],
      ]},
      { words:['안녕','하이','왔어','왔다'], aff:1, lines:[
        [`흥... 왔어? 기다린 거 아니야.`, 'O_default'],
        [`늦었잖아... 아니, 빨리 왔다는 의미야.`, 'O_default'],
        [`왔구나. 별로 반갑진 않아.`, 'O_default'],
      ]},
      { words:['좋아해','좋아하','사랑해','사랑'], aff:5, lines:[
        [`바, 바보야?! 그런 말 갑자기 하지마!!`, 'O_surprise'],
        [`...너 같은 거... 별로 안 좋아해. 정말로.`, 'O_default'],
        [`갑자기 무슨 소리야! 마음의 준비가...!`, 'O_surprise'],
      ]},
      { words:['예쁘','이쁘','귀여','귀엽'], aff:1, lines:[
        [`흥... 뭘 봐. 얼굴 빨개진 거 아니야.`, 'O_default'],
